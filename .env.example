# NiyyahMatch Backend Environment Variables
# Copy this file to .env and fill in your actual values

# JWT Secret Key (REQUIRED for production)
# Generate a strong random secret for production using:
# openssl rand -base64 64
JWT_SECRET=your-secure-jwt-secret-key-here-minimum-256-bits

# Database Configuration (Optional - defaults set in application.yml)
# DB_URL=jdbc:postgresql://localhost:5432/niyyahmatch
# DB_USERNAME=postgres
# DB_PASSWORD=your-password-here
